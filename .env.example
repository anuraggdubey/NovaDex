# ==========================================
# NovaDEX v2.0 — Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git
# ==========================================

# --- Stellar Network Config ---
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_AQUARIUS_API_URL=https://amm-api.aqua.network

# --- Supabase (Get from supabase.com > Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Soroban Contract IDs (Set after deploying contracts) ---
# Run: soroban contract deploy ... and paste the returned IDs here
NEXT_PUBLIC_AGGREGATOR_CONTRACT_ID=set_after_contract_deploy
NEXT_PUBLIC_ORACLE_CONTRACT_ID=set_after_contract_deploy

# --- Testnet Token Issuer (Set after running liquidity script) ---
# Run: node scripts/setup-testnet-liquidity.mjs and paste the issuer here
NEXT_PUBLIC_TESTNET_ISSUER=set_after_running_liquidity_script

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PROTOCOL_FEE_BPS=10

# ==========================================
# Mainnet overrides
# Change NEXT_PUBLIC_STELLAR_NETWORK=mainnet
# Change NEXT_PUBLIC_HORIZON_URL=https://horizon.stellar.org
# Remove NEXT_PUBLIC_TESTNET_ISSUER (mainnet uses real issuers)
# Redeploy contracts to mainnet, update contract IDs above
# ==========================================
